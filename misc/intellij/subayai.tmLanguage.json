{
    "name": "Subayai",
    "scopeName": "source.subayai",
    "fileTypes": [
        "yai"
    ],
    "patterns": [
        {
            "comment": "Single line comment",
            "match": "//.*$",
            "name": "comment.line.double-slash.subayai"
        },
        {
            "comment": "Strings",
            "begin": "\"",
            "end": "\"",
            "name": "string.quoted.double.subayai",
            "patterns": [
                {
                    "match": "\\\\.",
                    "name": "constant.character.escape.subayai"
                }
            ]
        },
        {
            "comment": "Keywords",
            "match": "\\b(if|else|switch|case|default|return|import|pkg|new|var|defer|break|continue|select)\\b",
            "name": "keyword.control.subayai"
        },
        {
            "comment": "Storage / Modifiers",
            "match": "\\b(class|lock|notlock|final|interface)\\b",
            "name": "storage.type.subayai"
        },
        {
            "comment": "Constants",
            "match": "\\b(true|false|nil)\\b",
            "name": "constant.language.subayai"
        },
        {
            "comment": "Numbers",
            "match": "\\b\\d+(\\.\\d+)?\\b",
            "name": "constant.numeric.subayai"
        },
        {
            "comment": "Built-in Sys",
            "match": "\\b(Sys)\\b",
            "name": "support.class.subayai"
        },
        {
            "comment": "Function Calls / Methods",
            "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)(?=\\()",
            "name": "entity.name.function.subayai"
        },
        {
            "comment": "Class Names (heuristic)",
            "match": "\\b[A-Z][a-zA-Z0-9_]*\\b",
            "name": "entity.name.type.class.subayai"
        },
        {
            "comment": "Operators",
            "match": "(\\+|\\-|\\*|/|%|==|!=|>|>=|<|<=|=|->)",
            "name": "keyword.operator.subayai"
        }
    ],
    "uuid": "ca03173a-4933-40f4-b258-00511871a4f0"
}